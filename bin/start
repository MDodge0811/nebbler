#!/usr/bin/env bash
set -euo pipefail

# Start the Expo dev server, auto-detecting worktree port configuration.
# Runs prebuild if ios/ doesn't exist, then launches with expo run:ios.
#
# In a worktree:  reads ports from ../api/.env, picks an offset Expo port
# In main repo:   uses default ports (API=4000, PowerSync=8080, Expo=8081)
#
# Usage: ./bin/start [expo args...]
#   ./bin/start              # prebuild (if needed) + run:ios
#   ./bin/start --android    # prebuild (if needed) + run:android

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
APP_DIR="$(dirname "$SCRIPT_DIR")"
API_ENV="$APP_DIR/../api/.env"

cd "$APP_DIR"

# Auto-detect worktree ports
if [[ -f "$API_ENV" ]]; then
  API_PORT=$(grep -E '^API_PORT=' "$API_ENV" | cut -d= -f2)
  POWERSYNC_PORT=$(grep -E '^POWERSYNC_PORT=' "$API_ENV" | cut -d= -f2)

  SLOT=$(( (API_PORT - 4000) / 100 ))
  EXPO_PORT=$(( 8081 + SLOT ))

  export API_PORT POWERSYNC_PORT

  echo "Worktree detected (slot $SLOT)"
  echo "  API:       localhost:$API_PORT"
  echo "  PowerSync: localhost:$POWERSYNC_PORT"
  echo "  Expo:      localhost:$EXPO_PORT"
  echo ""

  PORT_ARGS=(--port "$EXPO_PORT")
else
  PORT_ARGS=()
fi

# Determine platform from args (default: ios)
PLATFORM="ios"
REMAINING_ARGS=()
for arg in "$@"; do
  case "$arg" in
    --android) PLATFORM="android" ;;
    *) REMAINING_ARGS+=("$arg") ;;
  esac
done

# Prebuild if native directory doesn't exist
if [[ ! -d "$PLATFORM" ]]; then
  echo "Native $PLATFORM/ directory not found, running prebuild..."
  npx expo prebuild --platform "$PLATFORM"
  echo ""
fi

exec npx expo run:"$PLATFORM" "${PORT_ARGS[@]}" "${REMAINING_ARGS[@]}"
