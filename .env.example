# ===========================================
# Nebbler Mobile App Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# Values are picked up by app.config.ts and exposed via expo-constants.

# Clerk publishable key (starts with `pk_`)
# Find in Clerk dashboard → API Keys
CLERK_PUBLISHABLE_KEY=

# Worktree port overrides (optional — bin/start auto-detects)
# API_PORT=4000
# POWERSYNC_PORT=8080
