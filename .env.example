# ===========================================
# Nebbler Mobile App Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
#
# Expo automatically exposes any variable prefixed with EXPO_PUBLIC_ to the
# client bundle at build time. The Clerk SDK reads its publishable key directly
# from process.env, so no app.config.ts plumbing is required.
# Docs: https://clerk.com/docs/expo/getting-started/quickstart

# Clerk publishable key (starts with `pk_test_` or `pk_live_`).
# Find in Clerk dashboard → API Keys.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Worktree port overrides (optional — bin/start auto-detects)
# API_PORT=4000
# POWERSYNC_PORT=8080
